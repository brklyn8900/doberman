{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "Doberman",
  "version": "0.1.0",
  "identifier": "io.armana.doberman",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ]
  },
  "app": {
    "windows": [
      {
        "title": "Doberman",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "maximized": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: asset: 'unsafe-inline'; connect-src 'self' http://127.0.0.1:* http://localhost:* ipc: http://ipc.localhost"
    }
  }
}
